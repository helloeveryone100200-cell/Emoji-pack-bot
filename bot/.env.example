# ─── Required ─────────────────────────────────────────────────────────────────
# Telegram Bot Token (from @BotFather)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin User IDs (comma-separated Telegram user IDs)
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# ─── Render Auto-sets This ────────────────────────────────────────────────────
PORT=3000

# ─── Optional: Webhook (Render production URL) ────────────────────────────────
# Set this to your Render service URL for webhook mode (recommended for production)
# Leave empty for long-polling mode (development)
# Example: https://your-bot-name.onrender.com
WEBHOOK_URL=

# ─── Optional ─────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
